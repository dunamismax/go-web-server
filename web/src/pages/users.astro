---
import UsersDashboard from '../components/UsersDashboard.vue';
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Users | go-web-server">
  <section class="page-intro stack-md narrow">
    <p class="eyebrow">Protected Astro route</p>
    <h1>Manage users</h1>
    <p class="lead compact-lead">
      This page uses Astro + Vue on top of the documented <code>/api/users/*</code> contracts
      for the full managed-user workflow.
    </p>
  </section>

  <UsersDashboard client:load />
</AppLayout>
