---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'go-web-server migration shell' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Astro + Vue + Bun migration shell for the go-web-server frontend transition."
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
