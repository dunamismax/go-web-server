{
  "name": "go-web-server-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "bun run lint && astro check && bun run test",
    "test": "bun test ./src",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --config playwright.smoke.config.ts"
  },
  "dependencies": {
    "@astrojs/vue": "^6.0.1",
    "astro": "^6.1.2",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
